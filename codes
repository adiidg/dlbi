DL5_RNN_Sentiment_Analysis:

from tensorflow.keras.datasets import imdb
from tensorflow.keras.preprocessing.sequence import pad_sequences
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import Embedding, SimpleRNN, Dense

print("--- Problem 5: Sentiment Analysis (Simple RNN) ---")

max_features = 5000 
maxlen = 50          

# Load Data
(X_train, y_train), (X_test, y_test) = imdb.load_data(num_words=max_features)
X_train = pad_sequences(X_train, maxlen=maxlen)
X_test = pad_sequences(X_test, maxlen=maxlen)

# Build Simple RNN Computational Graph
model = Sequential([
    Embedding(input_dim=max_features, output_dim=64, input_length=maxlen),
    SimpleRNN(32, return_sequences=False), # Explicitly using RNN
    Dense(1, activation='sigmoid')
])

# RMSprop is generally a highly stable optimizer for basic RNNs
model.compile(optimizer='rmsprop', loss='binary_crossentropy', metrics=['accuracy'])

print("Training Simple RNN Sentiment Analyzer...")
model.fit(X_train, y_train, epochs=3, batch_size=64, validation_data=(X_test, y_test), verbose=1)

loss, acc = model.evaluate(X_test, y_test, verbose=0)
print(f"RNN Sentiment Accuracy: {acc * 100:.2f}%")




