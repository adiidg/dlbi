DL4_CNN_Image_Classification:

from tensorflow.keras.datasets import cifar10
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import Conv2D, MaxPooling2D, Flatten, Dense, Dropout
from tensorflow.keras.optimizers import Adam
from tensorflow.keras.utils import to_categorical

print("--- Problem 4: Optimized CNN for Image Classification ---")

# a. Select suitable dataset: CIFAR-10 (Colored images of planes, cars, birds, etc.)
(X_train, y_train), (X_test, y_test) = cifar10.load_data()
X_train, X_test = X_train / 255.0, X_test / 255.0
y_train, y_test = to_categorical(y_train, 10), to_categorical(y_test, 10)

# b. Optimized with different hyperparameters 
model = Sequential([
    # Hyperparameter: Filter size = 3x3, No. of Layers = 2 Conv Blocks
    Conv2D(32, kernel_size=(3, 3), activation='relu', input_shape=(32, 32, 3)), 
    MaxPooling2D(pool_size=(2, 2)),
    Dropout(0.2), # Hyperparameter: Dropout
    
    Conv2D(64, kernel_size=(3, 3), activation='relu'), 
    MaxPooling2D(pool_size=(2, 2)),
    Dropout(0.3), # Hyperparameter: Dropout
    
    Flatten(),
    Dense(128, activation='relu'),
    Dropout(0.4),
    Dense(10, activation='softmax')
])

# Hyperparameter: Custom Optimizer & Learning Rate (0.001)
custom_optimizer = Adam(learning_rate=0.001)

model.compile(optimizer=custom_optimizer, loss='categorical_crossentropy', metrics=['accuracy'])

print("Training Hyper-Optimized CNN...")
model.fit(X_train, y_train, epochs=5, batch_size=64, validation_split=0.2, verbose=1)

loss, acc = model.evaluate(X_test, y_test, verbose=0)
print(f"Optimized Model Accuracy: {acc * 100:.2f}%")




